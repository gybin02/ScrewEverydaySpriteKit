    "part_blue_wrench_story": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The first tool for apprentice repairers, tightening the most stubborn loose parts."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修理师学徒的第一件工具，能拧紧最顽固的松动件。"
          }
        }
      }
    },
    "part_copper_gear": {
