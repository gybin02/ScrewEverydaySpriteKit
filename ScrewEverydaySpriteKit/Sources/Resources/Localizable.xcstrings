      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From the old airship on the town's roof, it will take you above the clouds."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "来自小镇屋顶的旧飞艇，修好后还能带你看见云层。"
