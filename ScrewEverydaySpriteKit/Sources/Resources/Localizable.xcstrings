    "part_copper_gear_story": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The earliest rotating part of the machine tower, ticking like a steady heart gear."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "工坊机器塔最早转动的零件，像一圈沉稳的心脏齿轮。"
          }
        }
      }
    },
    "part_core_bearing": {
      "extractionState": "manual",
      "localizations": {
