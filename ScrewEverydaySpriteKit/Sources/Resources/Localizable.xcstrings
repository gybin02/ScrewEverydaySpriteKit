    "part_core_bearing_story": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The center that keeps the entire tower running steadily. Lighting up means repair is done."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让整座机器塔稳定运转的中心，亮起来就说明修复完成了。"
          }
        }
      }
    },
